rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 3. Primitive Definition ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isHardcodedAdmin() {
      return isVerified() && request.auth.token.email == 'mesyalendra21@gmail.com';
    }

    function isAdmin() { 
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isVerified() && (isHardcodedAdmin() || (exists(userPath) && get(userPath).data.role == 'admin')); 
    }

    function isPetugas() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isVerified() && exists(userPath) && get(userPath).data.role == 'petugas';
    }

    // --- 2. Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'role', 'balance', 'goldBalance', 'totalWasteKg', 'createdAt', 'displayName']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['nasabah', 'admin', 'petugas'] &&
             data.balance is number && data.balance >= 0 &&
             data.goldBalance is number && data.goldBalance >= 0 &&
             data.totalWasteKg is number &&
             data.createdAt is string &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'status', 'createdAt']) &&
             data.userId is string && isValidId(data.userId) &&
             data.type in ['deposit', 'conversion'] &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'completed'] &&
             data.createdAt is string;
    }

    // --- 4. Collection Rules ---

    match /users/{userId} {
      // PII Isolation: Only owner or admin/petugas can see full profile
      allow get: if isOwner(userId) || (isVerified() && (isHardcodedAdmin() || isAdmin() || isPetugas()));
      allow list: if isVerified() && (isHardcodedAdmin() || isAdmin() || isPetugas());

      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'nasabah';

      allow update: if isVerified() && (
        // Action: Self Update Display Name
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) && isValidUser(incoming())) ||
        // Action: System Sync (Balance/Gold) - Only allowed by Admin/Petugas OR Owner (demo logic)
        // In a real app, balance updates would only trigger via Cloud Functions or Admin
        ((isOwner(userId) || isPetugas() || isAdmin()) && 
         incoming().diff(existing()).affectedKeys().hasAny(['balance', 'goldBalance', 'totalWasteKg']) && 
         isValidUser(incoming()))
      );
    }

    match /transactions/{transactionId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin() || isPetugas());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin() || isPetugas());

      allow create: if isVerified() && isValidId(transactionId) &&
                   (isOwner(incoming().userId) || isPetugas() || isAdmin()) &&
                   isValidTransaction(incoming()) &&
                   // Relational Sync: Ensure user exists
                   exists(/databases/$(database)/documents/users/$(incoming().userId));

      allow update: if isVerified() && (isAdmin() || isPetugas()) && isValidTransaction(incoming());
      allow delete: if isAdmin();
    }

    match /wasteTypes/{typeId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /stats/{docId} {
      allow read: if isVerified();
      allow write: if isAdmin() || isPetugas();
    }
  }
}
