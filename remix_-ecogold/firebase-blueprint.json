{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile containing balance and gold accumulation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["nasabah", "admin", "petugas"] },
        "balance": { "type": "number", "description": "Current IDR balance" },
        "goldBalance": { "type": "number", "description": "Current gold weight in grams" },
        "totalWasteKg": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role", "balance", "goldBalance", "displayName", "totalWasteKg", "createdAt"]
    },
    "Transaction": {
      "title": "Waste Transaction",
      "description": "Record of waste deposits or gold conversions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "conversion"] },
        "wasteType": { "type": "string", "description": "Plastic, Paper, Metal, etc. (for deposit)" },
        "weight": { "type": "number", "description": "Waste weight in kg" },
        "amount": { "type": "number", "description": "IDR value" },
        "goldWeight": { "type": "number", "description": "Gold weight for conversion" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    },
    "WasteType": {
      "title": "Waste Type Price",
      "description": "Daily market prices for different waste types.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pricePerKg": { "type": "number" },
        "category": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "pricePerKg"]
    },
    "AppStats": {
      "title": "Global Application Stats",
      "description": "Aggregated data for environmental impact.",
      "type": "object",
      "properties": {
        "totalCo2Saved": { "type": "number" },
        "totalTreesSaved": { "type": "number" },
        "totalWasteProcessed": { "type": "number" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial and waste transaction history."
    },
    "wasteTypes/{typeId}": {
      "schema": "WasteType",
      "description": "Master data for waste pricing."
    },
    "stats/global": {
      "schema": "AppStats",
      "description": "Global statistics for gamification."
    }
  }
}
